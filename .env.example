# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=finuser
POSTGRES_PASSWORD=finpass
POSTGRES_DB=finanaliza
# asyncpg za FastAPI, psycopg2 za Alembic/Celery se derivira automatski
DATABASE_URL=postgresql+asyncpg://finuser:finpass@db:5432/finanaliza

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
# Generiši sa: openssl rand -hex 32
SECRET_KEY=change-me-generate-a-secure-random-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_FORECASTING=true
ENABLE_BENCHMARKS=false
