# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=finuser
POSTGRES_PASSWORD=finpass
POSTGRES_DB=finanaliza
# asyncpg za FastAPI, psycopg2 za Alembic/Celery se derivira automatski
DATABASE_URL=postgresql+asyncpg://finuser:finpass@db:5432/finanaliza

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
# Generiši sa: openssl rand -hex 32
SECRET_KEY=46682eb1fd7c6b4b4be401424ca66d426a8c81f6d4b371f547f3c4b8996c58a2
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5
ANTHROPIC_API_KEY=sk-ant-...

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_FORECASTING=true
ENABLE_BENCHMARKS=false
